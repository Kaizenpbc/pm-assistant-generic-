# ============================================================================
# PM Assistant — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# --- Core ---
NODE_ENV=development          # development | production | test
PORT=3001                     # Server port
HOST=0.0.0.0                  # Bind address

# --- Database (MariaDB/MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=                  # REQUIRED — no default
DB_NAME=pm_assistant_generic
DB_CONNECT_TIMEOUT=5000       # ms
DB_IDLE_TIMEOUT=30000         # ms
DB_QUEUE_LIMIT=50

# --- Security (all REQUIRED, must be unique, min 32 chars, min 8 unique chars) ---
JWT_SECRET=                   # REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=           # REQUIRED — must differ from JWT_SECRET
COOKIE_SECRET=                # REQUIRED — must differ from both JWT secrets

# --- CORS & URLs ---
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
LOG_LEVEL=debug               # error | warn | info | http | verbose | debug | silly

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=            # Optional — leave empty to disable AI features
AI_ENABLED=false              # Set true to enable AI features
AI_MODEL=claude-sonnet-4-5-20250929
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_FALLBACK_MODEL=claude-haiku-4-5-20251001
AI_FALLBACK_ENABLED=false     # Retry with fallback model on 429/503/timeout

# --- AI Budget & Pricing ---
AI_MONTHLY_TOKEN_BUDGET=500000      # Total tokens per month
AI_PRICING_INPUT=3.0                # USD per million input tokens
AI_PRICING_OUTPUT=15.0              # USD per million output tokens

# --- Email (Resend) ---
RESEND_API_KEY=               # Optional — leave empty to skip emails
RESEND_FROM_EMAIL=noreply@kpbc.ca

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=            # Optional
STRIPE_PUBLISHABLE_KEY=       # Optional
STRIPE_WEBHOOK_SECRET=        # Optional
STRIPE_PRO_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# --- Weather ---
WEATHER_API_PROVIDER=mock     # openweathermap | weatherapi | accuweather | mock
WEATHER_API_KEY=
WEATHER_CACHE_MINUTES=30

# --- Agent System ---
AGENT_ENABLED=false           # Enable autonomous agent scans
AGENT_CRON_SCHEDULE=0 2 * * * # Cron expression for agent scans
AGENT_DELAY_THRESHOLD_DAYS=3
AGENT_BUDGET_CPI_THRESHOLD=0.9
AGENT_BUDGET_OVERRUN_THRESHOLD=50
AGENT_MC_CONFIDENCE_LEVEL=80
AGENT_OVERDUE_SCAN_MINUTES=15

# --- Embeddings / RAG ---
OPENAI_API_KEY=               # Required for embeddings (uses OpenAI text-embedding model)
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3

# --- Redis ---
REDIS_URL=                    # Optional — e.g. redis://localhost:6379. Empty = disabled (in-memory fallback)

# --- Metrics ---
METRICS_ENABLED=true

# --- Alerting ---
ALERT_ENABLED=false
ALERT_EMAIL=                  # Email address for alert notifications
ALERT_WEBHOOK_URL=            # Webhook URL for alert notifications
ALERT_COOLDOWN_MINUTES=30     # Dedup window — same alert won't re-fire within this period

# --- Multi-Tenant ---
MULTI_TENANT_ENABLED=false    # Database-per-customer isolation

# --- File Uploads ---
UPLOAD_DIR=                   # Defaults to ~/uploads/pm-assistant
MAX_UPLOAD_SIZE_MB=10
